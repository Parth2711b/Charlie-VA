# Charlie v2 - Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to Git

# ── LLM ───────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Set to true + add API key to use Claude when online
CLOUD_LLM_ENABLED=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLOUD_MODEL=claude-sonnet-4-6

# ── Speech ────────────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WAKE_WORD_MODEL=hey_jarvis
TTS_VOICE=en_US-lessac-high
TTS_SPEED=1.0

# Full path to piper binary (if not in PATH)
# PIPER_BIN=C:\Users\YourName\piper\piper.exe

# ── Vision ────────────────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt
CAMERA_INDEX=0

# Windows: path to Tesseract install
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Actions ───────────────────────────────────────────────────────────────────
WHATSAPP_DEFAULT_WAIT=15
BROWSER_HEADLESS=false

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_DB_PATH=data/memory.db
MAX_CONTEXT_TURNS=10

# ── Research ──────────────────────────────────────────────────────────────────
MAX_SEARCH_RESULTS=5
SEARCH_TIMEOUT=10
